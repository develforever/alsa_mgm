{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "rootDir": "../",
        "outDir": "../../dist/backend",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "strictPropertyInitialization": false
    },
    "include": [
        "./**/*"
    ]
}